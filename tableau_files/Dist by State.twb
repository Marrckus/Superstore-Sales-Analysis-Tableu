      <column caption='summary' datatype='real' name='[Calculation_1280979315617794]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Sales]) &gt; 45000 THEN SUM([Sales])&#13;&#10;ELSE WINDOW_SUM(IF SUM([Sales]) &lt;= 45000 THEN SUM([Sales]) END)&#13;&#10;END'>
